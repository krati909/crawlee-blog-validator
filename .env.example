# .env.example
# Copy to .env for local development.  Never commit .env to version control.

# Target
BLOG_INDEX_URL=https://crawlee.dev/blog

# Crawler
MAX_ARTICLES=0          # 0 = no limit; set e.g. 5 for a quick smoke test
PAGE_SETTLE_MS=1500
MAX_REQUEST_RETRIES=3
MAX_CONCURRENCY=3

# Browser
HEADLESS=true           # Must be true in Lambda; set false for local debugging

# Validation
ALLOW_TRUNCATED_LABELS=true
FUZZY_MATCH_THRESHOLD=0.85

# Reporting
REPORT_OUTPUT_DIR=./reports
REPORT_INCLUDE_NORMALIZED=true

# Logging
LOG_LEVEL=INFO
